        "# 14. Simple RAG Pipeline\n",
        "from sentence_transformers import SentenceTransformer\n",
        "import faiss\n",
        "\n",
        "documents = [\"Paris is capital of France.\", \"Python is popular.\", \"AI is future.\"]\n",
        "embedder = SentenceTransformer('all-MiniLM-L6-v2')\n",
        "doc_emb = embedder.encode(documents)\n",
        "\n",
        "index = faiss.IndexFlatL2(doc_emb.shape[1])\n",
        "index.add(doc_emb)\n",
        "\n",
        "def retrieve(query, k=2):\n",
        "    q_emb = embedder.encode([query])\n",
        "    _, idx = index.search(q_emb, k)\n",
        "    return [documents[i] for i in idx[0]]\n",
        "\n",
        "print(retrieve(\"capital of France\"))"
      ],
